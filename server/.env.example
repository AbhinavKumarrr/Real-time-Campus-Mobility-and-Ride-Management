# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
# Use a local MongoDB or a MongoDB Atlas connection string.
MONGO_URI=mongodb://127.0.0.1:27017/campus_ride

# Set to "true" to run an in-memory MongoDB (no install needed).
# Great for quick demos / development. Data is NOT persisted.
USE_MEMORY_DB=false

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CLIENT_ORIGIN=http://localhost:5173
